{
  "name": "@openclaw/credential-vault",
  "version": "0.1.0",
  "description": "OpenClaw credential vault plugin — encrypts, injects, and scrubs external tool credentials",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:resolver": "cd resolver && cargo build --release --target x86_64-unknown-linux-musl",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:resolver": "cd resolver && cargo test",
    "test:cross": "vitest run tests/cross-compat.test.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
