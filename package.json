{
  "name": "openclaw-credential-vault",
  "version": "1.0.0-beta.7",
  "description": "OpenClaw credential vault plugin — encrypts, injects, and scrubs external tool credentials",
  "main": "dist/index.js",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "bin/",
    "openclaw.plugin.json",
    "tools/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:resolver": "cd resolver && cargo build --release --target x86_64-unknown-linux-musl",
    "postinstall": "node -e \"const p=require('path').resolve(__dirname,'bin','vault-setup.sh'); console.log('\\n✓ Credential Vault installed\\n\\nComplete setup:\\n  sudo bash '+p+'\\n')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:resolver": "cd resolver && cargo test",
    "test:cross": "vitest run tests/cross-compat.test.ts",
    "verify-install": "bash tests/install-verify/run.sh",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "credential",
    "vault",
    "secrets",
    "encryption"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/karanuppal/openclaw-credential-vault.git"
  },
  "bugs": {
    "url": "https://github.com/openclaw/credential-vault/issues"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "yaml": "^2.7.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
