# Install verification base image — Alpine
# Contains Node 22 + OpenClaw. Does NOT include the vault plugin.
FROM alpine:3.20

RUN apk add --no-cache \
      curl sudo bash ca-certificates jq git nodejs npm \
    && npm install -g openclaw

# Create a non-root user for realistic install testing
# Alpine uses adduser, not useradd
RUN adduser -D -s /bin/bash testuser \
    && echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Perl intentionally NOT installed — setup script should auto-install it.

USER testuser
WORKDIR /home/testuser

COPY entrypoint.sh /verify/entrypoint.sh
# install.sh is mounted at runtime from the project root via -v

ENTRYPOINT ["bash", "/verify/entrypoint.sh"]
