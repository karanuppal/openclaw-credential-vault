# Install verification base image — Debian 12
# Contains Node 22 + OpenClaw + git. Does NOT include the vault plugin.
FROM debian:12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
      curl sudo ca-certificates gnupg jq git \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && npm install -g openclaw \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Create a non-root user for realistic install testing
RUN useradd -m -s /bin/bash testuser \
    && echo "testuser ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Perl is intentionally NOT installed in the base image.
# The setup script (vault-setup.sh) should install it automatically.
# This lets us verify the Perl auto-install and missing-Perl warnings.

USER testuser
WORKDIR /home/testuser

COPY entrypoint.sh /verify/entrypoint.sh
# install.sh is mounted at runtime from the project root via -v

ENTRYPOINT ["bash", "/verify/entrypoint.sh"]
