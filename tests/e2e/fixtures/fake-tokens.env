# Fake tokens for E2E testing
# These look real enough to trigger auto-detection but are obviously fake.
# They are deliberately different from scrub markers ([VAULT:name]).
#
# NEVER use real credentials here. These are committed to git.

FAKE_GITHUB_PAT="ghp_FAKETOKEN0123456789abcdefghijklmnop"
FAKE_NPM_TOKEN=[VAULT:env-redacted]
FAKE_OPENAI_KEY=[VAULT:env-redacted]
FAKE_BROWSER_PASSWORD=[VAULT:env-redacted]
FAKE_BROWSER_COOKIE="session_FAKECOOKIE0123456789abcdef"
FAKE_SPECIAL_CHARS='p@$$w0rd!#%^&*()'
FAKE_CUSTOM_API_KEY=[VAULT:env-redacted]
FAKE_GITHUB_PAT_ROTATED="ghp_ROTATEDTOKEN9876543210zyxwvutsrqpo"
FAKE_NEWCRED_KEY=[VAULT:env-redacted]
FAKE_LONG_CREDENTIAL=[VAULT:env-redacted] -c "print('A' * 4096)" 2>/dev/null || printf '%4096s' '' | tr ' ' 'A')"
